{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@nuro7/contracts": [
        "packages/contracts/src"
      ],
      "@nuro7/contracts/*": [
        "packages/contracts/src/*"
      ]
    }
  }
}

