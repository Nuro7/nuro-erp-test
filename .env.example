# ===== Database (Supabase free) =====
# Supabase Dashboard > Project Settings > Database > Connection string (URI)
# Use the pooler URL (port 6543) for production
DATABASE_URL="postgresql://postgres.<project>:<password>@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# ===== JWT secrets (generate: openssl rand -hex 32) =====
JWT_ACCESS_SECRET="replace-with-access-secret-min-16-chars"
JWT_REFRESH_SECRET="replace-with-refresh-secret-min-16-chars"
JWT_ACCESS_TTL="365d"
JWT_REFRESH_TTL="365d"

# ===== App URLs =====
# Production: your Vercel domain (e.g. https://nuro7.com)
APP_URL="http://localhost:3000"
# Production: your Render API URL (e.g. https://nuro-api.onrender.com/api/v1)
API_URL="http://localhost:4000/api/v1"
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"
# Comma-separated origins allowed by API CORS + WebSocket
CORS_ORIGIN="http://localhost:3000,http://localhost:3001"

# ===== Email (Resend — 3k/mo free) =====
SMTP_HOST="smtp.resend.com"
SMTP_PORT="587"
SMTP_USER="resend"
SMTP_PASS="re_xxx_replace_with_resend_api_key"

# ===== File storage =====
# "local" for dev, "s3" for prod (Supabase Storage / AWS S3 / Cloudflare R2)
FILE_STORAGE_DRIVER="local"
LOCAL_UPLOAD_DIR="./uploads"

# Supabase Storage (S3-compatible). Get from Supabase Dashboard > Storage > Settings
# Endpoint format: https://<project-ref>.supabase.co/storage/v1/s3
AWS_REGION="ap-south-1"
AWS_S3_BUCKET="nuro-uploads"
AWS_S3_ENDPOINT=""
# Public URL for serving uploaded files
# Format: https://<project-ref>.supabase.co/storage/v1/object/public/nuro-uploads
AWS_S3_PUBLIC_URL=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# ===== Reverse proxy (Render/Vercel handle this) =====
TRUST_PROXY="1"

# ===== Render-specific (Render injects PORT automatically) =====
# PORT="10000"

# ===== Client portal =====
# In production set PORTAL_ENABLED=true and PORTAL_URL=https://your-portal-domain
# Without these the API 404s every /api/v1/client-portal/* route and magic
# links point to localhost.
PORTAL_ENABLED="false"
PORTAL_URL="http://localhost:3000"
# Session TTL — refreshed on every authenticated request. 1 year by default;
# effectively "client stays signed in until they go quiet for a year, or
# until staff revoke the contact from the admin UI".
PORTAL_SESSION_TTL_DAYS="365"
# Magic-link expiry is NOT enforced at verify time — links are permanent
# and reusable until the contact is deactivated. This value only affects
# the `expiresAt` column stored in the DB row. Override only if you
# specifically want time-boxed links (then also re-enable the check in
# portal-auth.service.ts).
PORTAL_MAGIC_LINK_TTL_MINUTES="5256000"
