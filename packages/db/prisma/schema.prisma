// ══════════════════════════════════════════════════════════════════
// ACCOUNTING — Payments
// ══════════════════════════════════════════════════════════════════

enum PaymentType {
  RECEIVED
  MADE
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CARD
  CHECK
  UPI
  OTHER
}

model Payment {
  id                 String              @id @default(cuid())
  paymentNumber      String              @unique
  type               PaymentType
  amount             Decimal             @db.Decimal(14, 2)
  paymentDate        DateTime            @db.Date
  method             PaymentMethod       @default(BANK_TRANSFER)
  reference          String?
  notes              String?
  // Lightweight tag for expense-style Payments (type=MADE). Drives the
  // /expenses dashboard categorisation; nullable so old data + non-expense
  // payments don't carry a category.
  expenseCategory    ExpenseCategory?
  // Set when this Payment was generated from a RecurringExpense template.
  recurringExpenseId String?
  recurringExpense   RecurringExpense?   @relation(fields: [recurringExpenseId], references: [id], onDelete: SetNull)
  clientId           String?
  client             Client?             @relation(fields: [clientId], references: [id], onDelete: SetNull)
  vendorId           String?
  vendor             Vendor?             @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  bankAccountId      String?
  bankAccount        BankAccount?        @relation(fields: [bankAccountId], references: [id], onDelete: SetNull)
  createdById        String
  createdBy          User                @relation("PaymentCreator", fields: [createdById], references: [id], onDelete: Restrict)
  allocations        PaymentAllocation[]
  bankTxns           BankTransaction[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([clientId])
  @@index([vendorId])
  @@index([paymentDate])
  @@index([expenseCategory])
  @@index([recurringExpenseId])
}

enum ExpenseCategory {
  RENT
  UTILITIES
  INTERNET
  SUBSCRIPTION
  OFFICE_SUPPLIES
  TRAVEL
  MEALS
  EQUIPMENT
  MARKETING
  PROFESSIONAL_FEES
  SALARY
  INSURANCE
  REPAIRS
  TRAINING
  TAXES
  OTHER
}

enum ExpenseFrequency {
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  YEARLY
}

/// Template for a recurring outflow (rent, SaaS subs, utilities, etc.).
/// Each cycle the generate-due job converts this into a Payment row with
/// type=MADE, which then auto-posts to the GL through the normal payment
/// hook. lastGeneratedFor records the period (YYYY-MM-01 anchored) so we
/// can compute the next due date deterministically without scanning all
/// past payments.
model RecurringExpense {
  id                String           @id @default(cuid())
  title             String
  category          ExpenseCategory  @default(OTHER)
  vendorId          String?
  vendor            Vendor?          @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  amount            Decimal          @db.Decimal(14, 2)
  method            PaymentMethod    @default(BANK_TRANSFER)
  bankAccountId     String?
  bankAccount       BankAccount?     @relation(fields: [bankAccountId], references: [id], onDelete: SetNull)
  frequency         ExpenseFrequency @default(MONTHLY)
  // For MONTHLY: 1–31 (clamps to month end). For QUARTERLY/YEARLY:
  // anniversary day used along with startDate to derive each cycle.
  dayOfMonth        Int              @default(1)
  startDate         DateTime         @db.Date
  endDate           DateTime?        @db.Date
  isActive          Boolean          @default(true)
  // Anchored first-of-month / first-of-quarter / first-of-year date of
  // the last cycle that was generated. Null means never generated.
  lastGeneratedFor  DateTime?        @db.Date
  notes             String?
  createdById       String
  createdBy         User             @relation("RecurringExpenseCreator", fields: [createdById], references: [id], onDelete: Restrict)
  generatedPayments Payment[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([isActive])
  @@index([category])
}

model PaymentAllocation {
  id        String   @id @default(cuid())
  paymentId String
  payment   Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  billId    String?
  bill      Bill?    @relation(fields: [billId], references: [id], onDelete: SetNull)
  amount    Decimal  @db.Decimal(14, 2)
  createdAt DateTime @default(now())

  @@index([paymentId])
  @@index([invoiceId])
  @@index([billId])
}

// ══════════════════════════════════════════════════════════════════
// ACCOUNTING — Credit Notes
// ══════════════════════════════════════════════════════════════════

enum CreditNoteStatus {
  DRAFT
  OPEN
  CLOSED
  VOID
}

model CreditNote {
