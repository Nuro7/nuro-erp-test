  unit                  String                 @default("pcs")
  incomeAccountId       String?
  incomeAccount         ChartAccount?          @relation("ItemIncomeAccount", fields: [incomeAccountId], references: [id], onDelete: SetNull)
  expenseAccountId      String?
  expenseAccount        ChartAccount?          @relation("ItemExpenseAccount", fields: [expenseAccountId], references: [id], onDelete: SetNull)
  taxRateId             String?
  taxRate               TaxRate?               @relation(fields: [taxRateId], references: [id], onDelete: SetNull)
  isActive              Boolean                @default(true)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  invoiceItems          InvoiceItem[]
  estimateItems         EstimateItem[]
  billItems             BillItem[]
  creditNoteItems       CreditNoteItem[]
  recurringInvoiceItems RecurringInvoiceItem[]
}

model OrganizationSettings {
  id                String   @id @default(cuid())
  name              String   @default("Nuro7")
  legalName         String?
  logoUrl           String?
  email             String?
  phone             String?
  website           String?
  addressLine1      String?
  addressLine2      String?
  city              String?
  state             String?
  postalCode        String?
  country           String?  @default("India")
  taxId             String?
  fiscalYearStart   String   @default("APRIL")
  baseCurrency      String   @default("INR")
  invoicePrefix     String   @default("INV-")
  invoiceTerms      String?
  invoiceFooter     String?
  estimatePrefix    String   @default("EST-")
  billPrefix        String   @default("BILL-")
  creditNotePrefix  String   @default("CN-")
  paymentTerms      Int      @default(30)
  // Bank details shown on the invoice template
  bankName          String?
  bankAccountNumber String?
  bankAccountHolder String?
  bankBranch        String?
  bankIfsc          String?
  bankUpi           String?
  // Optional circular stamp/seal image rendered on the invoice
  stampUrl          String?
  // "About us" narrative shown in the proposal template
  aboutCompany      String?
  /**
   * CEO / authorised signatory name used in the proposal cover letter and signature blocks.
   */
  ceoName           String?
  /**
   * Optional title to show beneath ceoName (defaults to "CEO").
   */
  ceoTitle          String?
  /**
   * Default hourly billing rate (in baseCurrency) used by AI proposal generation and time-based invoicing.
   */
  defaultHourlyRate Decimal? @default(900) @db.Decimal(10, 2)
  /**
   * Universal Terms & Conditions rendered on the printed proposal (one clause per line).
   * Separate from invoiceTerms — proposal T&Cs are stricter and more protective by design.
   */
  proposalTerms     String?
  /// Outbound SMTP credentials. Stored here (not env) so SUPER_ADMIN can
  /// rotate them from the Settings → Email page without redeploying. Only
  /// the password is treated as a write-only secret in the API.
  smtpHost          String?
  smtpPort          Int?
  smtpUser          String?
  smtpPass          String?
  smtpFrom          String?
