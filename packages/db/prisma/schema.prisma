model CreditNoteItem {
  id           String     @id @default(cuid())
  creditNoteId String
  creditNote   CreditNote @relation(fields: [creditNoteId], references: [id], onDelete: Cascade)
  itemId       String?
  item         Item?      @relation(fields: [itemId], references: [id], onDelete: SetNull)
  description  String
  quantity     Decimal    @db.Decimal(10, 2)
  price        Decimal    @db.Decimal(12, 2)
  taxRateId    String?
  taxRate      TaxRate?   @relation(fields: [taxRateId], references: [id], onDelete: SetNull)
  taxAmount    Decimal    @default(0) @db.Decimal(12, 2)
  total        Decimal    @db.Decimal(12, 2)
  sortOrder    Int        @default(0)
}

// ══════════════════════════════════════════════════════════════════
// ACCOUNTING — Bank Accounts & Reconciliation
// ══════════════════════════════════════════════════════════════════

enum BankAccountType {
  BANK
  CASH
  CREDIT_CARD
}

model BankAccount {
  id                String             @id @default(cuid())
  name              String
  type              BankAccountType    @default(BANK)
  accountNumber     String?
  bankName          String?
  currency          String             @default("INR")
  openingBalance    Decimal            @default(0) @db.Decimal(14, 2)
  currentBalance    Decimal            @default(0) @db.Decimal(14, 2)
  accountId         String?
  account           ChartAccount?      @relation(fields: [accountId], references: [id], onDelete: SetNull)
  // Exactly one BankAccount should be marked primary at a time. Auto-
  // posting routes everything (invoice payments, bill payments, payroll,
  // founder draws/loans) through this account when no other bank is
  // specified on the payment. Uniqueness is enforced by the service
  // layer rather than a DB constraint so demoting + promoting in a
  // single transaction stays clean.
  isPrimary         Boolean            @default(false)
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  payments          Payment[]
  transactions      BankTransaction[]
  recurringExpenses RecurringExpense[]
}

enum BankTxnType {
  DEBIT
  CREDIT
}

model BankTransaction {
  id             String        @id @default(cuid())
  bankAccountId  String
  bankAccount    BankAccount   @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  date           DateTime      @db.Date
  amount         Decimal       @db.Decimal(14, 2)
  type           BankTxnType
  description    String
  reference      String?
  categoryId     String?
  category       ChartAccount? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  reconciledAt   DateTime?
  paymentId      String?
  payment        Payment?      @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  // Auto-post mirror anchor: when AutoPostService writes a BankTransaction
  // to mirror a JournalEntry's cash-side, it stores the JE id here.
  // Backfill checks for missing mirrors via this column so it can fill
  // in bank-side entries that were skipped (e.g. JE posted before a
  // primary bank existed, then bank added later). Uniqueness enforced
  // at the service layer (DB-level @unique can't be added without an
  // interactive prisma migrate prompt).
  journalEntryId String?
  journalEntry   JournalEntry? @relation(fields: [journalEntryId], references: [id], onDelete: SetNull)
  createdAt      DateTime      @default(now())

  @@index([bankAccountId])
  @@index([date])
  @@index([journalEntryId])
}

// ══════════════════════════════════════════════════════════════════
// ACCOUNTING — Manual Journal Entries
// ══════════════════════════════════════════════════════════════════

// Source of a JournalEntry. AUTO entries are written by the auto-post
// service when an upstream record (Payment, PaySlip, FounderLedgerEntry)
// is created; MANUAL entries are hand-keyed in the /journal-entries page.
// Idempotency (a re-run / retry can't double-book) is enforced in the
// service layer by checking findFirst(source, sourceId) before insert.
enum JournalEntrySource {
  MANUAL
  PAYMENT
  PAY_SLIP
  FOUNDER_LEDGER
  OPENING_BALANCE
  CREDIT_NOTE
}

model JournalEntry {
  id               String             @id @default(cuid())
  journalNumber    String             @unique
  date             DateTime           @db.Date
  description      String
  reference        String?
  source           JournalEntrySource @default(MANUAL)
  // Pointer back to the originating record (Payment.id, PaySlip.id,
  // FounderLedgerEntry.id) so the dashboard can deep-link from a journal
  // row to the source document. Null for MANUAL entries.
  sourceId         String?
  createdById      String
  createdBy        User               @relation("JournalCreator", fields: [createdById], references: [id], onDelete: Restrict)
  lines            JournalLine[]
  bankTransactions BankTransaction[]
  createdAt        DateTime           @default(now())

  @@index([date])
  @@index([source, sourceId])
}

model JournalLine {
  id          String       @id @default(cuid())
  journalId   String
  journal     JournalEntry @relation(fields: [journalId], references: [id], onDelete: Cascade)
  accountId   String
  account     ChartAccount @relation(fields: [accountId], references: [id], onDelete: Restrict)
  debit       Decimal      @default(0) @db.Decimal(14, 2)
  credit      Decimal      @default(0) @db.Decimal(14, 2)
  description String?
  sortOrder   Int          @default(0)

  @@index([journalId])
  @@index([accountId])
}

// ══════════════════════════════════════════════════════════════════
// ACCOUNTING — Recurring Invoices
// ══════════════════════════════════════════════════════════════════

enum Frequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum RecurringStatus {
  ACTIVE
  PAUSED
  ENDED
}

model RecurringInvoice {
  id          String                 @id @default(cuid())
  name        String
  clientId    String
  client      Client                 @relation(fields: [clientId], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project?               @relation(fields: [projectId], references: [id], onDelete: SetNull)
  frequency   Frequency              @default(MONTHLY)
  startDate   DateTime               @db.Date
  endDate     DateTime?              @db.Date
  nextRunDate DateTime               @db.Date
  lastRunDate DateTime?              @db.Date
  status      RecurringStatus        @default(ACTIVE)
  subtotal    Decimal                @db.Decimal(14, 2)
  taxAmount   Decimal                @default(0) @db.Decimal(14, 2)
  total       Decimal                @db.Decimal(14, 2)
  notes       String?
  createdById String
  createdBy   User                   @relation("RecurringInvoiceCreator", fields: [createdById], references: [id], onDelete: Restrict)
  items       RecurringInvoiceItem[]
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
}

model RecurringInvoiceItem {
  id                 String           @id @default(cuid())
  recurringInvoiceId String
  recurringInvoice   RecurringInvoice @relation(fields: [recurringInvoiceId], references: [id], onDelete: Cascade)
  itemId             String?
  item               Item?            @relation(fields: [itemId], references: [id], onDelete: SetNull)
  description        String
  quantity           Decimal          @db.Decimal(10, 2)
  price              Decimal          @db.Decimal(12, 2)
  taxRateId          String?
  taxRate            TaxRate?         @relation(fields: [taxRateId], references: [id], onDelete: SetNull)
  total              Decimal          @db.Decimal(12, 2)
  sortOrder          Int              @default(0)
}

// ══════════════════════════════════════════════════════════════════
// HRM — Payroll
// ══════════════════════════════════════════════════════════════════

model SalaryStructure {
  id               String          @id @default(cuid())
  employeeId       String          @unique
  employee         EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  basic            Decimal         @db.Decimal(12, 2)
  hra              Decimal         @default(0) @db.Decimal(12, 2)
  conveyance       Decimal         @default(0) @db.Decimal(12, 2)
  medical          Decimal         @default(0) @db.Decimal(12, 2)
  specialAllowance Decimal         @default(0) @db.Decimal(12, 2)
  otherAllowance   Decimal         @default(0) @db.Decimal(12, 2)
  pfDeduction      Decimal         @default(0) @db.Decimal(12, 2)
  taxDeduction     Decimal         @default(0) @db.Decimal(12, 2)
  otherDeductions  Decimal         @default(0) @db.Decimal(12, 2)
  effectiveFrom    DateTime        @db.Date
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

enum PayrollStatus {
  DRAFT
  PROCESSED
  PAID
}

model PayrollRun {
  id              String        @id @default(cuid())
  month           Int
  year            Int
  status          PayrollStatus @default(DRAFT)
  processedAt     DateTime?
  processedById   String?
  processedBy     User?         @relation("PayrollProcessor", fields: [processedById], references: [id], onDelete: SetNull)
  totalGross      Decimal       @default(0) @db.Decimal(14, 2)
  totalDeductions Decimal       @default(0) @db.Decimal(14, 2)
  totalNet        Decimal       @default(0) @db.Decimal(14, 2)
  slips           PaySlip[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([month, year])
}

enum PaySlipStatus {
  PENDING
  PAID
}

model PaySlip {
  id               String          @id @default(cuid())
  payrollRunId     String
  payrollRun       PayrollRun      @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employeeId       String
  employee         EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  month            Int
  year             Int
  basic            Decimal         @db.Decimal(12, 2)
  hra              Decimal         @default(0) @db.Decimal(12, 2)
  allowances       Decimal         @default(0) @db.Decimal(12, 2)
  grossSalary      Decimal         @db.Decimal(12, 2)
  pfDeduction      Decimal         @default(0) @db.Decimal(12, 2)
  taxDeduction     Decimal         @default(0) @db.Decimal(12, 2)
  otherDeductions  Decimal         @default(0) @db.Decimal(12, 2)
  netSalary        Decimal         @db.Decimal(12, 2)
  // Founder-only deferred-compensation fields. drawnAmount is what the
  // founder actually withdrew this month (defaults to netSalary = full
  // draw); deferredAmount is the gap they're subsidising the company by.
  // For non-founders these stay at netSalary / 0 respectively and the UI
  // hides them.
  drawnAmount      Decimal?        @db.Decimal(12, 2)
  deferredAmount   Decimal         @default(0) @db.Decimal(12, 2)
  workingDays      Int
  paidDays         Int
  leaveDays        Int             @default(0)
  status           PaySlipStatus   @default(PENDING)
  paidAt           DateTime?
  paymentReference String?
  createdAt        DateTime        @default(now())

  @@unique([payrollRunId, employeeId])
  @@index([employeeId])
}

