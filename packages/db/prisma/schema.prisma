// ══════════════════════════════════════════════════════════════════
// Co-founder bookkeeping — capital account ledger + cap table
// ══════════════════════════════════════════════════════════════════

// Direction of a capital-account entry from the founder's perspective.
// CREDIT increases the company's IOU to the founder (loan from founder,
// reimbursement owed). DEBIT decreases it (founder took a distribution,
// company repaid the loan).
enum FounderLedgerDirection {
  CREDIT
  DEBIT
}

enum FounderLedgerKind {
  LOAN_IN // Founder lent cash to the company (CREDIT)
  EXPENSE_REIMBURSEMENT // Founder paid an expense out of pocket; pending repay (CREDIT)
  DISTRIBUTION // Founder took a draw / dividend (DEBIT)
  REPAYMENT // Company paid back part of the IOU (DEBIT)
  OTHER // Catch-all so HR can describe edge cases manually
}

// A single capital-account transaction for a founder. Deferred salary
// from pay slips is NOT stored here — it lives on PaySlip.deferredAmount
// and is rolled up alongside ledger entries at read time so we have one
// source of truth per data type.
model FounderLedgerEntry {
  id          String                 @id @default(cuid())
  employeeId  String
  employee    EmployeeProfile        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date        DateTime               @db.Date
  direction   FounderLedgerDirection
  kind        FounderLedgerKind
  // Always stored as a positive number; `direction` carries the sign so
  // we can index/aggregate without worrying about negative-decimal math.
  amount      Decimal                @db.Decimal(14, 2)
  description String?
  reference   String? // optional external ref (cheque #, txn id, etc.)
  createdById String
  createdBy   User                   @relation("FounderLedgerCreator", fields: [createdById], references: [id])
  createdAt   DateTime               @default(now())

  @@index([employeeId, date])
  @@index([kind])
}

// Equity grant to a founder or employee (ESOP). Vesting is computed at
// read time from grantDate + cliffMonths + vestingMonths so we don't
// have to write a job that updates vested totals every day. Hand-rolled
// math beats a cron for this volume.
enum EquityGrantStatus {
  ACTIVE
  CANCELLED
  EXERCISED
}

enum EquityGrantType {
  FOUNDER_SHARES
  ESOP
  INVESTOR
  ADVISOR
  OTHER
}

model EquityGrant {
  id               String           @id @default(cuid())
  // Internal grants link to an EmployeeProfile; external grants (e.g.
  // outside investors, advisors who aren't employees) leave employeeId
  // null and fill the holder* fields below.
  employeeId       String?
  employee         EmployeeProfile? @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  // External-holder fields. Required when employeeId is null (enforced
  // by the service, not the DB, so DB-level edits stay flexible).
  holderName       String?
  holderEmail      String?
  organization     String? // VC firm, fund, advisor org, etc.
  // Cash side of an investment round. Mostly meaningful for type=INVESTOR
  // but allowed on any grant for completeness (e.g. an advisor who
  // exercised cash-warrants).
  investmentAmount Decimal?         @db.Decimal(14, 2)
  investmentDate   DateTime?        @db.Date

  type          EquityGrantType   @default(FOUNDER_SHARES)
  // Number of shares granted (whole shares for simplicity). For % views
  // we divide by CompanyValuation.totalShares at read time.
  shares        Int
  // Vesting schedule. cliffMonths=0 + vestingMonths=0 means fully vested
  // on grantDate (common for founder shares + investor shares).
  // cliffMonths=12 + vestingMonths=48 is the standard "4-year vest with
  // 1-year cliff".
  grantDate     DateTime          @db.Date
  vestingMonths Int               @default(0)
  cliffMonths   Int               @default(0)
  status        EquityGrantStatus @default(ACTIVE)
  notes         String?
  createdById   String
  createdBy     User              @relation("EquityGrantCreator", fields: [createdById], references: [id])
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([employeeId])
  @@index([type])
  @@index([status])
}

// Snapshot of the company's total share count and most-recent valuation.
// We keep history because new investment rounds change both numbers and
// you want a dated trail of the cap-table evolution. Reads use the most
// recent row (max asOf).
model CompanyValuation {
  id          String   @id @default(cuid())
  // Total issued shares (sum of all EquityGrant.shares + treasury, etc.)
  // as of asOf. Used as the denominator for ownership %.
  totalShares Int
  // Per-share valuation (post-money / latest 409A / whatever you anchor
  // on). Stored in the company's reporting currency (₹).
  sharePrice  Decimal  @db.Decimal(14, 4)
  asOf        DateTime @db.Date
  notes       String?
  createdById String
  createdBy   User     @relation("ValuationCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  @@index([asOf])
}

// ─────────────────────────────────────────────────────────────────────────────
// Credential vault — encrypted store for team secrets (passwords, API keys,
// SSH keys, DB connection strings, certificates, env files, free-form notes).
//
// Threat model: the database may be backed up, cloned, or read by a DBA. The
// `ciphertext` column is AES-256-GCM encrypted at rest with a key that lives
// outside the DB (CREDENTIAL_VAULT_KEY env). Plaintext fields (name, username,
// url, tags, type) stay searchable; everything secret goes into the encrypted
// JSON payload. Access is row-level: owner + explicit shares only, with an
// append-only audit log of every reveal/share/rotation.
// ─────────────────────────────────────────────────────────────────────────────

enum CredentialType {
  PASSWORD
  API_KEY
  SSH_KEY
  DATABASE
  CERTIFICATE
  ENV_FILE
  CARD
  NOTE
  // Dedicated high-value types — surfaced separately because they ship with
  // platform pickers, recovery-email/phone fields, and 2FA backup codes, and
  // because they typically warrant `requiresReason=true` on reveal.
  SOCIAL_MEDIA
  EMAIL_ACCOUNT
  GENERIC
}

enum CredentialAccessRole {
  VIEWER // can reveal & view
  EDITOR // can update + share
  OWNER // full control (transferred via ownership change)
}

enum CredentialAuditAction {
  CREATED
  UPDATED
  REVEALED // user decrypted the secret payload
  SHARED
  UNSHARED
  ROLE_CHANGED
  ROTATED // secret value replaced
  DELETED
  RENAMED
  FOLDER_MOVED
}

model CredentialFolder {
  id          String             @id @default(cuid())
  name        String
  description String?
  // Color hex stored as #RRGGBB — used to tint the folder card in the UI.
  color       String?
  parentId    String?
  parent      CredentialFolder?  @relation("CredentialFolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    CredentialFolder[] @relation("CredentialFolderTree")
  credentials Credential[]
  createdById String
  createdBy   User               @relation("CredentialFolderCreator", fields: [createdById], references: [id])
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([parentId])
  @@index([createdById])
}

model Credential {
  id                   String             @id @default(cuid())
  name                 String
  type                 CredentialType     @default(PASSWORD)
  description          String?
  // Username / login / email associated with the credential. Searchable.
  username             String?
  // URL or host the credential is for. Surface in the list for quick scan.
  url                  String?
  // AES-256-GCM payload — format: base64(iv).base64(ciphertext).base64(tag)
  // Holds the JSON {password, apiKey, privateKey, cert, value, notes, ...}.
  ciphertext           String             @db.Text
  // Unencrypted structured metadata (provider name, scope, region, fingerprint).
  // Never put secrets here — only what you'd be OK with the DBA reading.
  metadata             Json?
  // Optional natural-expiry. Cron surfaces a renewal notification.
  expiresAt            DateTime?
  // Rotation tracking — `rotationIntervalDays` lets the cron job nag.
  lastRotatedAt        DateTime?
  rotationIntervalDays Int?
  // Free-form tags for filtering (e.g. ["prod", "aws", "billing"]).
  tags                 String[]           @default([])
  // When true, the reveal endpoint requires the caller to submit a short
  // justification ("why are you opening this right now?") which is stored
  // on the audit row. Recommended for SOCIAL_MEDIA and EMAIL_ACCOUNT.
  requiresReason       Boolean            @default(false)
  // Tightens the client-side auto-relock + flags the row visually as a
  // "high-stakes" credential. Stored on the model so the policy travels
  // with the row regardless of who is viewing it.
  highSecurity         Boolean            @default(false)
  folderId             String?
  folder               CredentialFolder?  @relation(fields: [folderId], references: [id], onDelete: SetNull)
  ownerId              String
  owner                User               @relation("CredentialOwner", fields: [ownerId], references: [id])
  accesses             CredentialAccess[]
  auditLogs            CredentialAudit[]
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([ownerId])
  @@index([folderId])
  @@index([type])
  @@index([expiresAt])
}

model CredentialAccess {
  id           String               @id @default(cuid())
  credentialId String
  credential   Credential           @relation(fields: [credentialId], references: [id], onDelete: Cascade)
  userId       String
  user         User                 @relation("CredentialAccessUser", fields: [userId], references: [id], onDelete: Cascade)
  role         CredentialAccessRole @default(VIEWER)
  grantedById  String
  grantedBy    User                 @relation("CredentialAccessGranter", fields: [grantedById], references: [id])
  grantedAt    DateTime             @default(now())

  @@unique([credentialId, userId])
  @@index([userId])
}

model CredentialAudit {
  id           String                @id @default(cuid())
  credentialId String
  credential   Credential            @relation(fields: [credentialId], references: [id], onDelete: Cascade)
  userId       String
  user         User                  @relation("CredentialAuditor", fields: [userId], references: [id], onDelete: Cascade)
  action       CredentialAuditAction
  ipAddress    String?
  userAgent    String?
  metadata     Json?
  createdAt    DateTime              @default(now())

  @@index([credentialId, createdAt])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Studio — marketing planner, social media planner, product ideas, team tools.
// All four sit alongside (not inside) the project/task system because they're
// workspace-level concerns, not project deliverables. Each entity has its own
// lightweight checklist where applicable — we deliberately don't reuse the
// heavy Task model since these are quick todos, not billable work.
// ─────────────────────────────────────────────────────────────────────────────

enum MarketingIdeaStage {
  IDEA
  PLANNED
  IN_PROGRESS
  REVIEW
  LIVE
  DONE
  CANCELLED
}

enum MarketingIdeaPriority {
  LOW
  MEDIUM
  HIGH
}

model MarketingIdea {
  id          String                @id @default(cuid())
  title       String
  description String?
  // The actual marketing copy / draft. Markdown-ish, free-form. Lives here
  // (not in a separate Document) because campaigns iterate quickly and the
  // round-trip to a doc CMS just adds friction.
  content     String?
  stage       MarketingIdeaStage    @default(IDEA)
  priority    MarketingIdeaPriority @default(MEDIUM)
  // Target ship date — surfaces in the planner and on the calendar overlay.
  targetDate  DateTime?
  // Channel hints (blog, email, social, paid, etc.) — free-form tags so the
  // team doesn't have to wait for us to add an enum value.
  tags        String[]              @default([])
  ownerId     String
  owner       User                  @relation("MarketingIdeaOwner", fields: [ownerId], references: [id])
  tasks       MarketingIdeaTask[]
  socialPosts SocialPost[]
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([stage])
  @@index([ownerId])
  @@index([targetDate])
}

model MarketingIdeaTask {
  id              String        @id @default(cuid())
  marketingIdeaId String
  marketingIdea   MarketingIdea @relation(fields: [marketingIdeaId], references: [id], onDelete: Cascade)
  title           String
  completed       Boolean       @default(false)
  assignedToId    String?
  assignedTo      User?         @relation("MarketingTaskAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  dueDate         DateTime?
  sortOrder       Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([marketingIdeaId, sortOrder])
}

enum SocialPlatform {
  TWITTER
  FACEBOOK
  INSTAGRAM
  LINKEDIN
  YOUTUBE
  TIKTOK
  THREADS
  PINTEREST
  REDDIT
  WHATSAPP
  TELEGRAM
  OTHER
}

enum SocialPostStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  FAILED
  CANCELLED
}

model SocialPost {
  id              String           @id @default(cuid())
  // Optional short title for the row in the planner; falls back to content
  // excerpt when blank so the UI always has something to show.
  title           String?
  content         String
  platform        SocialPlatform
  status          SocialPostStatus @default(DRAFT)
  // When the team intends to release the post. The planner calendar groups
  // entries by this date.
  scheduledAt     DateTime?
  // When the post actually went live. Set by the team (we don't auto-post
  // yet); keeps the timeline honest if the schedule slips.
  publishedAt     DateTime?
  // Media attachments — file URLs (S3/local). Stored as plain strings so
  // anything that can be linked (image, video, PDF) fits without schema work.
  mediaUrls       String[]         @default([])
  // External link — once the post is live, paste the platform URL so the
  // team can jump straight to it.
  link            String?
  marketingIdeaId String?
  marketingIdea   MarketingIdea?   @relation(fields: [marketingIdeaId], references: [id], onDelete: SetNull)
  ownerId         String
  owner           User             @relation("SocialPostOwner", fields: [ownerId], references: [id])
  // Internal scheduling note — what to remember when posting, the angle, etc.
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([platform])
  @@index([status])
  @@index([scheduledAt])
  @@index([ownerId])
}

enum ProductIdeaStatus {
  IDEA
  VALIDATING
  PLANNED
  BUILDING
  SHIPPED
  REJECTED
}

model ProductIdea {
  id            String            @id @default(cuid())
  title         String
  description   String?
  // Why this matters — the problem statement / customer need. Separates
  // "we should build X" from "here's why we should build X".
  rationale     String?
  // How we'd know it worked. Forces a measurable framing on each idea.
  successMetric String?
  status        ProductIdeaStatus @default(IDEA)
  // Up-vote count cached on the model — incremented/decremented by the vote
  // toggle endpoint so the board can sort by popularity without a join.
  voteCount     Int               @default(0)
  targetDate    DateTime?
  tags          String[]          @default([])
  ownerId       String
  owner         User              @relation("ProductIdeaOwner", fields: [ownerId], references: [id])
  tasks         ProductIdeaTask[]
  votes         ProductIdeaVote[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([status])
  @@index([ownerId])
  @@index([voteCount])
}

model ProductIdeaTask {
  id            String      @id @default(cuid())
  productIdeaId String
  productIdea   ProductIdea @relation(fields: [productIdeaId], references: [id], onDelete: Cascade)
  title         String
  completed     Boolean     @default(false)
  assignedToId  String?
  assignedTo    User?       @relation("ProductTaskAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  dueDate       DateTime?
  sortOrder     Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([productIdeaId, sortOrder])
}

// One vote per user per idea — uniqueness enforced by the composite key.
model ProductIdeaVote {
  id            String      @id @default(cuid())
  productIdeaId String
  productIdea   ProductIdea @relation(fields: [productIdeaId], references: [id], onDelete: Cascade)
  userId        String
  user          User        @relation("ProductIdeaVoter", fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@unique([productIdeaId, userId])
  @@index([userId])
}

enum TeamToolCategory {
  AI
  DESIGN
  DEVELOPMENT
  MARKETING
  PRODUCTIVITY
  ANALYTICS
  COMMUNICATION
  RESEARCH
  OTHER
}

model TeamTool {
  id          String           @id @default(cuid())
  name        String
  description String?
  url         String
  // Optional brand / favicon URL — falls back to a generated initials chip.
  iconUrl     String?
  category    TeamToolCategory @default(OTHER)
  // Pinned tools appear at the top of the tools page for quick access.
  isPinned    Boolean          @default(false)
  // Separate flag from category so AI tools can also live under specific
  // categories (e.g. an AI design tool is both AI=true and category=DESIGN).
  isAi        Boolean          @default(false)
  // Free-form tags for filtering inside the directory.
  tags        String[]         @default([])
  addedById   String
  addedBy     User             @relation("TeamToolAddedBy", fields: [addedById], references: [id])
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([category])
  @@index([isPinned])
}

// ─────────────────────────────────────────────────────────────────────────────
// Per-user module access overrides — sits on top of role-based defaults so an
// admin can grant a specific employee access to a module their role wouldn't
// normally see, or deny one their role does see. Stored sparsely: one row per
// override, and the absence of a row means "use the role default".
//
// `moduleKey` matches the contracts/src/modules.ts ModuleKey union so the same
// string powers nav filtering on both API and web. Kept as a String column
// (not an enum) so adding a new module in code doesn't require a migration.
// ─────────────────────────────────────────────────────────────────────────────

enum AccessOverride {
  GRANT // explicitly grant the module even if the user's role wouldn't
  DENY // explicitly hide the module even if the user's role normally would
}

model UserModuleAccess {
  id          String         @id @default(cuid())
  userId      String
  user        User           @relation("UserModuleAccessUser", fields: [userId], references: [id], onDelete: Cascade)
  moduleKey   String
  override    AccessOverride
  grantedById String
  grantedBy   User           @relation("UserModuleAccessGranter", fields: [grantedById], references: [id])
  note        String? // optional rationale captured for the audit trail
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([userId, moduleKey])
  @@index([userId])
}
