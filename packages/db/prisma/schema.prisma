generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleCode {
  SUPER_ADMIN
  ADMIN
  PROJECT_MANAGER
  HR_MANAGER
  FINANCE_MANAGER
  EMPLOYEE
  CLIENT
}

enum PermissionAction {
  READ
  CREATE
  UPDATE
  DELETE
  APPROVE
  EXPORT
  SEND
  INVITE
  ASSIGN
  COMMENT
  UPLOAD
}

enum UserStatus {
  INVITED
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum MilestoneStatus {
  NOT_STARTED
  IN_PROGRESS
  BLOCKED
  DONE
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  REVIEW
  DONE
  BLOCKED
}

enum TaskStatusCategory {
  TODO
  IN_PROGRESS
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ClientPriority {
  LOW
  MEDIUM
  HIGH
  VIP
}

enum LeaveType {
  ANNUAL
  SICK
  CASUAL
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

// How a LeaveRequest was originated. REQUESTED is the normal user-initiated
// flow; the AUTO_* variants are created by the attendance engine when a
// late check-in or half-day-cutoff arrival triggers an automatic deduction.
enum LeaveSource {
  REQUESTED
  AUTO_HALF_DAY
  AUTO_LATE_PENALTY
}

// Status of an Attendance row computed at clock-in time. PRESENT means the
// employee arrived within the grace window; LATE means past grace but
// before the half-day cutoff; HALF_DAY means at-or-after the half-day
// cutoff (auto-deducts 0.5 leave); ABSENT is set by a daily sweep when no
// check-in exists on a working day; HOLIDAY is a non-working day.
enum AttendanceStatus {
  PRESENT
  LATE
  HALF_DAY
  ABSENT
  ON_LEAVE
  HOLIDAY
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  VOID
}

enum ProposalStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum TransactionType {
  EXPENSE
  REVENUE
  TRANSFER
  PAYROLL
  REFUND
}

enum NotificationChannel {
  IN_APP
  EMAIL
}

enum NotificationStatus {
  UNREAD
  READ
  ARCHIVED
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_MENTIONED
  TASK_WATCHER_ACTIVITY
  TASK_DUE_SOON
  TASK_COMMENT
  SPRINT_STARTED
  PROJECT_ADDED
  PROJECT_MEMBER_ADDED
  PROJECT_DEADLINE_SOON
  PROJECT_OVERDUE
  CHAT_MENTIONED
  LEAVE_APPROVED
  LEAVE_REJECTED
  HOLIDAY_UPCOMING
  ANNOUNCEMENT_POSTED
  ATTENDANCE_ABSENT
  ATTENDANCE_MISSED_PUNCH
  ATTENDANCE_HALF_DAY_AUTO
  ATTENDANCE_LATE_STREAK
  ACCOUNT_CREATED
  GENERIC
}

/// PasswordResetToken serves two distinct flows:
///   RESET        — user clicked "Forgot password"; 30-minute TTL; on
///                  use, all of their refresh tokens are revoked.
///   INITIAL_SET  — issued by HR on account create; 24-hour TTL;
///                  on use, no refresh revoke (user has no prior sessions).
/// The discriminator avoids merging the two flows into a single TTL/
/// post-action that would be wrong for one side.
enum PasswordResetTokenKind {
  RESET
  INITIAL_SET
}

enum DocumentEntityType {
  PROJECT
  CLIENT
  EMPLOYEE
  FINANCE
  GENERAL
}

enum DocumentStorage {
  LOCAL
  S3
}

model User {
  id                           String                  @id @default(cuid())
  email                        String                  @unique
  passwordHash                 String
  firstName                    String
  lastName                     String
  avatarUrl                    String?
  phone                        String?
  status                       UserStatus              @default(INVITED)
  emailVerifiedAt              DateTime?
  lastLoginAt                  DateTime?
  createdAt                    DateTime                @default(now())
  updatedAt                    DateTime                @updatedAt
  employeeProfile              EmployeeProfile?
  directReports                EmployeeProfile[]       @relation("EmployeeManager")
  hrNotesAuthored              HrNote[]                @relation("HrNoteAuthor")
  employmentEventsCreated      EmploymentStatusEvent[] @relation("EmploymentEventCreator")
  founderLedgerEntriesCreated  FounderLedgerEntry[]    @relation("FounderLedgerCreator")
  equityGrantsCreated          EquityGrant[]           @relation("EquityGrantCreator")
  valuationsCreated            CompanyValuation[]      @relation("ValuationCreator")
  sessions                     Session[]
  refreshTokens                RefreshToken[]
  passwordResetTokens          PasswordResetToken[]
  verificationTokens           VerificationToken[]
  roles                        UserRole[]
  authoredProjects             Project[]               @relation("ProjectManager")
  projectMemberships           ProjectMember[]
  assignedTasks                Task[]                  @relation("AssignedTasks")
  taskComments                 TaskComment[]
  taskAttachments              TaskAttachment[]
  timeEntries                  TimeEntry[]
  attendanceLogs               Attendance[]
  leaveBalances                LeaveBalance[]
  leaveRequests                LeaveRequest[]          @relation("LeaveRequester")
  leaveApprovals               LeaveRequest[]          @relation("LeaveApprover")
  clientContacts               Client[]                @relation("ClientPortalUser")
  accountManagedClients        Client[]                @relation("ClientAccountManager")
  invoicesCreated              Invoice[]               @relation("InvoiceCreatedBy")
  proposalsCreated             Proposal[]
  resourceAllocations          ResourceAllocation[]
  documentsUploaded            Document[]
  notifications                Notification[]
  expensesCreated              Expense[]               @relation("ExpenseCreatedBy")
  revenuesCreated              Revenue[]               @relation("RevenueCreatedBy")
  transactionsCreated          Transaction[]           @relation("TransactionCreatedBy")
  createdReports               ReportExport[]
  activityLogs                 ActivityLog[]
  assignedLeads                Lead[]                  @relation("LeadAssignee")
  knowledgeArticles            KnowledgeArticle[]      @relation("ArticleAuthor")
  goals                        Goal[]                  @relation("GoalAssignee")
  organizedEvents              CalendarEvent[]         @relation("EventOrganizer")
  communications               Communication[]         @relation("CommunicationCreator")
  emailTemplates               EmailTemplate[]         @relation("TemplateCreator")
  wikiPages                    ProjectWikiPage[]       @relation("WikiAuthor")
  dealsOwned                   Deal[]                  @relation("DealOwner")
  activitiesCreated            Activity[]              @relation("ActivityCreator")
  activitiesAssigned           Activity[]              @relation("ActivityAssignee")
  estimatesCreated             Estimate[]              @relation("EstimateCreator")
  billsCreated                 Bill[]                  @relation("BillCreator")
  paymentsCreated              Payment[]               @relation("PaymentCreator")
  recurringExpensesCreated     RecurringExpense[]      @relation("RecurringExpenseCreator")
  projectClientMessages        ProjectClientMessage[]  @relation("UserProjectMessages")
  creditNotesCreated           CreditNote[]            @relation("CreditNoteCreator")
  journalsCreated              JournalEntry[]          @relation("JournalCreator")
  recurringInvoicesCreated     RecurringInvoice[]      @relation("RecurringInvoiceCreator")
  payrollRuns                  PayrollRun[]            @relation("PayrollProcessor")
  reviewsAsEmployee            PerformanceReview[]     @relation("ReviewEmployee")
  reviewsAsReviewer            PerformanceReview[]     @relation("ReviewReviewer")
  feedback360Given             Review360Feedback[]     @relation("Feedback360Reviewer")
  shiftSchedules               ShiftSchedule[]         @relation("ShiftUser")
  assetsAssigned               Asset[]                 @relation("AssetAssignee")
  announcements                Announcement[]          @relation("AnnouncementPublisher")
  timesheets                   TimesheetSubmission[]   @relation("TimesheetUser")
  timesheetsApproved           TimesheetSubmission[]   @relation("TimesheetApprover")
  savedViews                   SavedView[]             @relation("SavedViewsUser")
  recurringTasksAssigned       RecurringTaskTemplate[] @relation("RecurringTaskAssignee")
  recurringTasksCreated        RecurringTaskTemplate[] @relation("RecurringTaskCreator")
  timeEntriesApproved          TimeEntry[]             @relation("TimeEntryApprover")
  taskWatchers                 TaskWatcher[]           @relation("TaskWatcher")
  retrospectivesCreated        SprintRetrospective[]   @relation("RetroCreator")
  channelsCreated              Channel[]               @relation("ChannelsCreated")
  channelMembers               ChannelMember[]         @relation("ChannelMembers")
  chatMessages                 ChatMessage[]           @relation("ChatMessagesAuthored")
  chatReactions                ChatReaction[]          @relation("ChatReactions")
  projectExpensesCreated       ProjectExpense[]        @relation("ProjectExpensesCreated")
  clientRequestMessages        ClientRequestMessage[]
  credentialsOwned             Credential[]            @relation("CredentialOwner")
  credentialAccesses           CredentialAccess[]      @relation("CredentialAccessUser")
  credentialAccessesGranted    CredentialAccess[]      @relation("CredentialAccessGranter")
  credentialAuditEvents        CredentialAudit[]       @relation("CredentialAuditor")
  credentialFoldersCreated     CredentialFolder[]      @relation("CredentialFolderCreator")
  marketingIdeasOwned          MarketingIdea[]         @relation("MarketingIdeaOwner")
  marketingTasksAssigned       MarketingIdeaTask[]     @relation("MarketingTaskAssignee")
  socialPostsOwned             SocialPost[]            @relation("SocialPostOwner")
  productIdeasOwned            ProductIdea[]           @relation("ProductIdeaOwner")
  productTasksAssigned         ProductIdeaTask[]       @relation("ProductTaskAssignee")
  teamToolsAdded               TeamTool[]              @relation("TeamToolAddedBy")
  productIdeaVotes             ProductIdeaVote[]       @relation("ProductIdeaVoter")
  moduleAccessOverrides        UserModuleAccess[]      @relation("UserModuleAccessUser")
  moduleAccessOverridesGranted UserModuleAccess[]      @relation("UserModuleAccessGranter")
}

model Session {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress  String?
  userAgent  String?
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
}

model PasswordResetToken {
  id        String                 @id @default(cuid())
  userId    String
  user      User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String                 @unique
  expiresAt DateTime
  usedAt    DateTime?
  kind      PasswordResetTokenKind @default(RESET)
  createdAt DateTime               @default(now())
}

model VerificationToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
}

model Role {
  id          String           @id @default(cuid())
  code        RoleCode         @unique
  name        String
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  permissions RolePermission[]
  users       UserRole[]
}

model Permission {
  id          String           @id @default(cuid())
  resource    String
  action      PermissionAction
  name        String
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  roles       RolePermission[]

  @@unique([resource, action])
}

model UserRole {
  id         String   @id @default(cuid())
  userId     String
  roleId     String
  assignedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model Client {
  id                String             @id @default(cuid())
  companyName       String
  contactPerson     String?
  email             String?            @unique
  phone             String?
  address           String?
  website           String?
  notes             String?
  industry          String?
  city              String?
  country           String?
  priority          ClientPriority     @default(MEDIUM)
  status            String             @default("ACTIVE")
  accountManagerId  String?
  accountManager    User?              @relation("ClientAccountManager", fields: [accountManagerId], references: [id], onDelete: SetNull)
  tags              String[]           @default([])
  nextFollowUpAt    DateTime?
  referralSource    String?
  acquiredAt        DateTime?          @db.Date
  portalEnabled     Boolean            @default(false)
  portalUserId      String?
  customFields      Json?
  portalUser        User?              @relation("ClientPortalUser", fields: [portalUserId], references: [id], onDelete: SetNull)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  projects          Project[]
  contracts         Contract[]
  invoices          Invoice[]
  proposals         Proposal[]
  documents         Document[]
  leadConversion    Lead?              @relation("LeadConversion")
  contacts          Contact[]
  deals             Deal[]
  activities        Activity[]
  estimates         Estimate[]
  payments          Payment[]
  creditNotes       CreditNote[]
  recurringInvoices RecurringInvoice[]
  clientContacts    ClientContact[]
  clientRequests    ClientRequest[]
}

model Contract {
  id        String    @id @default(cuid())
  clientId  String
  client    Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title     String
  startDate DateTime
  endDate   DateTime?
  value     Decimal   @db.Decimal(12, 2)
  status    String
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Project {
  id                  String                    @id @default(cuid())
  name                String
  clientId            String
  client              Client                    @relation(fields: [clientId], references: [id], onDelete: Restrict)
  description         String?
  startDate           DateTime
  endDate             DateTime?
  budget              Decimal                   @db.Decimal(12, 2)
  // Per-project hourly billing rate. Falls back to
  // OrganizationSettings.defaultHourlyRate when null. Used by the
  // proposal generator + AI plan budget calculation so each engagement
  // can carry its own contracted rate without overwriting the org-wide
  // default for other projects.
  hourlyRate          Decimal?                  @db.Decimal(10, 2)
  status              ProjectStatus             @default(PLANNING)
  managerId           String
  manager             User                      @relation("ProjectManager", fields: [managerId], references: [id], onDelete: Restrict)
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  milestones          Milestone[]
  members             ProjectMember[]
  tasks               Task[]
  timeEntries         TimeEntry[]
  invoices            Invoice[]
  proposals           Proposal[]
  resourceAllocations ResourceAllocation[]
  documents           Document[]
  sprints             Sprint[]
  labels              Label[]
  wikiPages           ProjectWikiPage[]
  estimates           Estimate[]
  recurringInvoices   RecurringInvoice[]
  recurringTasks      RecurringTaskTemplate[]   @relation("RecurringTaskProject")
  customStatuses      ProjectTaskStatus[]       @relation("ProjectCustomStatuses")
  channels            Channel[]                 @relation("ProjectChannel")
  expenses            ProjectExpense[]          @relation("ProjectExpenses")
  bills               Bill[]                    @relation("BillProject")
  paymentMilestones   ProjectPaymentMilestone[]
  clientRequests      ClientRequest[]
  clientMessages      ProjectClientMessage[]    @relation("ProjectMessages")
}

/// Per-project chat between the client (ClientContact) and staff
/// (User). Either fromContact or fromUser is set, never both. Surfaces
/// on the portal as "Chat" tab and on the staff side as a project
/// thread, so clients can DM the team without leaving the portal.
model ProjectClientMessage {
  id            String         @id @default(cuid())
  projectId     String
  project       Project        @relation("ProjectMessages", fields: [projectId], references: [id], onDelete: Cascade)
  content       String
  fromContactId String?
  fromContact   ClientContact? @relation("ContactProjectMessages", fields: [fromContactId], references: [id], onDelete: SetNull)
  fromUserId    String?
  fromUser      User?          @relation("UserProjectMessages", fields: [fromUserId], references: [id], onDelete: SetNull)
  readAt        DateTime?
  createdAt     DateTime       @default(now())

  @@index([projectId, createdAt])
}

enum PaymentMilestoneStatus {
  PENDING // not yet billed
  INVOICED // invoice generated but not paid
  PAID // invoice paid
  SKIPPED // PM marked as not applicable
}

model ProjectPaymentMilestone {
  id         String                 @id @default(cuid())
  projectId  String
  project    Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  label      String // "Advance", "Mid-project", "Final" — editable
  percentage Decimal                @db.Decimal(6, 2) // 50.00, 30.00, 20.00 (0 for extras)
  // Extras / change orders carry a direct rupee amount instead of a %
  // of the project budget. They sit ALONGSIDE the regular schedule and
  // do NOT count toward the 100% cap. `amount` is null for regular
  // (percentage-based) milestones.
  isExtra    Boolean                @default(false)
  amount     Decimal?               @db.Decimal(12, 2)
  sortOrder  Int                    @default(0)
  status     PaymentMilestoneStatus @default(PENDING)
  invoiceId  String?                @unique
  invoice    Invoice?               @relation("MilestoneInvoice", fields: [invoiceId], references: [id], onDelete: SetNull)
  dueDate    DateTime?              @db.Date
  notes      String?
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt

  @@index([projectId])
  @@index([status])
}

model ProjectMember {
  id         String   @id @default(cuid())
  projectId  String
  userId     String
  roleLabel  String
  allocation Int      @default(0)
  joinedAt   DateTime @default(now())
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model Milestone {
  id          String          @id @default(cuid())
  projectId   String
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  dueDate     DateTime?
  status      MilestoneStatus @default(NOT_STARTED)
  tasks       Task[]          @relation("MilestoneTasks")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model Task {
  id              String                 @id @default(cuid())
  projectId       String
  project         Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  assignedToId    String?
  assignedTo      User?                  @relation("AssignedTasks", fields: [assignedToId], references: [id], onDelete: SetNull)
  status          TaskStatus             @default(TODO)
  isClientVisible Boolean                @default(false)
  customStatusId  String?
  customStatus    ProjectTaskStatus?     @relation("TaskCustomStatus", fields: [customStatusId], references: [id], onDelete: SetNull)
  recurringTaskId String?
  recurringTask   RecurringTaskTemplate? @relation("RecurringTaskGenerated", fields: [recurringTaskId], references: [id], onDelete: SetNull)
  priority        Priority               @default(MEDIUM)
  startDate       DateTime?
  dueDate         DateTime?
  estimatedHrs    Decimal?               @db.Decimal(8, 2)
  parentId        String?
  parent          Task?                  @relation("Subtasks", fields: [parentId], references: [id], onDelete: SetNull)
  subtasks        Task[]                 @relation("Subtasks")
  sprintId        String?
  sprint          Sprint?                @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  milestoneId     String?
  milestone       Milestone?             @relation("MilestoneTasks", fields: [milestoneId], references: [id], onDelete: SetNull)
  storyPoints     Int?
  progressPercent Int                    @default(0)
  sortOrder       Int                    @default(0)
  reminderSentAt  DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  comments        TaskComment[]
  attachments     TaskAttachment[]
  timeEntries     TimeEntry[]
  labels          TaskLabel[]
  watchers        TaskWatcher[]
  blockedBy       TaskDependency[]       @relation("BlockedTask")
  blocking        TaskDependency[]       @relation("BlockingTask")
  clientRequests  ClientRequest[]
}

// ── Sprints / Iterations ──

enum SprintStatus {
  PLANNED
  ACTIVE
  COMPLETED
}

model Sprint {
  id                String                   @id @default(cuid())
  projectId         String
  project           Project                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name              String
  goal              String?
  startDate         DateTime                 @db.Date
  endDate           DateTime                 @db.Date
  status            SprintStatus             @default(PLANNED)
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  tasks             Task[]
  burndownSnapshots SprintBurndownSnapshot[] @relation("SprintBurndown")
  retrospective     SprintRetrospective?     @relation("SprintRetro")
}

// ── Labels / Tags ──

model Label {
  id        String      @id @default(cuid())
  name      String
  color     String      @default("#64748b")
  projectId String?
  project   Project?    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())
  tasks     TaskLabel[]

  @@unique([name, projectId])
}

model TaskLabel {
  taskId  String
  labelId String
  task    Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label   Label  @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([taskId, labelId])
}

// ── Task Dependencies ──

model TaskDependency {
  id         String   @id @default(cuid())
  blockedId  String
  blockingId String
  blocked    Task     @relation("BlockedTask", fields: [blockedId], references: [id], onDelete: Cascade)
  blocking   Task     @relation("BlockingTask", fields: [blockingId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([blockedId, blockingId])
}

// ── Project Wiki (Notion-like docs) ──

model ProjectWikiPage {
  id        String            @id @default(cuid())
  projectId String
  project   Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title     String
  content   String
  parentId  String?
  parent    ProjectWikiPage?  @relation("WikiNesting", fields: [parentId], references: [id], onDelete: SetNull)
  children  ProjectWikiPage[] @relation("WikiNesting")
  authorId  String
  author    User              @relation("WikiAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  sortOrder Int               @default(0)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TaskAttachment {
  id           String   @id @default(cuid())
  taskId       String
  task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedById String
  uploadedBy   User     @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  fileUrl      String
  fileName     String
  createdAt    DateTime @default(now())
}

model TimeEntry {
  id              String                  @id @default(cuid())
  userId          String
  projectId       String
  taskId          String?
  user            User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project         Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task            Task?                   @relation(fields: [taskId], references: [id], onDelete: SetNull)
  startTime       DateTime
  endTime         DateTime?
  duration        Int?
  notes           String?
  billable        Boolean                 @default(true)
  // Approval workflow — optional per-entry approval for billable time
  approvalStatus  TimeEntryApprovalStatus @default(PENDING)
  approvedById    String?
  approvedBy      User?                   @relation("TimeEntryApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime                @default(now())

  @@index([userId])
  @@index([projectId])
  @@index([taskId])
  @@index([startTime])
}

model Attendance {
  id          String           @id @default(cuid())
  userId      String
  date        DateTime         @db.Date
  checkIn     DateTime?
  checkOut    DateTime?
  totalHours  Decimal?         @db.Decimal(6, 2)
  status      AttendanceStatus @default(PRESENT)
  lateMinutes Int              @default(0)
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([userId, date])
  @@index([date])
  @@index([userId, date])
  @@index([status])
}

model LeaveBalance {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  leaveType LeaveType
  totalDays Decimal   @db.Decimal(5, 2)
  usedDays  Decimal   @default(0) @db.Decimal(5, 2)
  remaining Decimal   @db.Decimal(5, 2)
  updatedAt DateTime  @updatedAt

  @@unique([userId, leaveType])
}

model LeaveRequest {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation("LeaveRequester", fields: [userId], references: [id], onDelete: Cascade)
  leaveType    LeaveType
  startDate    DateTime    @db.Date
  endDate      DateTime    @db.Date
  status       LeaveStatus @default(PENDING)
  reason       String?
  approvedById String?
  approvedBy   User?       @relation("LeaveApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  // Half-day support: when true the request consumes 0.5 day per covered
  // date. `days` stores the resolved total (1.0 for full day, 0.5 half).
  isHalfDay    Boolean     @default(false)
  days         Decimal     @default(1) @db.Decimal(5, 2)
  // How this request was created — user-initiated vs auto-generated by
  // the attendance engine (half-day cutoff arrival, or 3-late penalty).
  source       LeaveSource @default(REQUESTED)
  // Resolved at create-time: whether this leave consumes one of the
  // employee's monthly paid leaves (true) or is logged as unpaid because
  // the monthly cap was already exhausted (false).
  isPaid       Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([userId, startDate])
  @@index([status])
}

// Singleton attendance policy. The service reads the first row (or falls
// back to coded defaults that mirror the @default() values below). Only
// SUPER_ADMIN / HR_MANAGER mutate this; everyone reads.
model AttendancePolicy {
  id                  String   @id @default(cuid())
  // Office start/end times. Hour columns kept for backwards compatibility
  // with code paths that don't yet read minutes — new code always pairs the
  // Hour with the Minute column. Defaults preserve the prior 10:00 → 18:00.
  officeStartHour     Int      @default(10) // 24-h, e.g. 10 = 10:00
  officeStartMinute   Int      @default(0) // 0..59
  officeEndHour       Int      @default(18) // 24-h, e.g. 18 = 18:00
  officeEndMinute     Int      @default(0) // 0..59
  graceMinutes        Int      @default(10) // minutes after officeStart that still count as PRESENT
  halfDayCutoffHour   Int      @default(12) // check-in at/after this hour auto-marks HALF_DAY
  halfDayCutoffMinute Int      @default(0)
  // Hours each employee is expected to work per day (default 8.0). Drives
  // the "expected check-out" hint and rolls into time-tracking targets.
  // Decimal so 7.5 or 8.5-hour days are supported.
  requiredDailyHours  Decimal  @default(8) @db.Decimal(4, 2)
  lateStreakThreshold Int      @default(3) // every Nth LATE in a month deducts one paid leave
  monthlyPaidLeaveCap Int      @default(2) // free paid leaves per calendar month before unpaid kicks in
  // Working days bitmask: bit 0 = Sun, bit 1 = Mon, ..., bit 6 = Sat.
  // Default 126 = bits 1..6 set = Mon-Sat. Stored as a single int so we
  // don't need Postgres array support.
  workingDaysMask     Int      @default(126)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model EmployeeProfile {
  id                 String                  @id @default(cuid())
  userId             String                  @unique
  user               User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  department         String
  designation        String
  salary             Decimal                 @db.Decimal(12, 2)
  hourlyRate         Decimal?                @db.Decimal(10, 2)
  joinDate           DateTime                @db.Date
  employmentType     EmploymentType
  managerName        String? // legacy free-text fallback
  managerId          String?
  manager            User?                   @relation("EmployeeManager", fields: [managerId], references: [id], onDelete: SetNull)
  emergencyContact   String?
  performanceScore   Decimal?                @db.Decimal(4, 2)
  // Co-founder marker — gates deferred-compensation features (the founder
  // dashboard card, the inline "Drawn" editor on their pay slips, the
  // Founder badge on the profile header). Regular employees never opt
  // into deferred draw.
  isFounder          Boolean                 @default(false)
  weeklyCapacityHrs  Decimal                 @default(40) @db.Decimal(5, 2)
  // Per-employee shift override (24-h clock). When null, attendance
  // falls back to the org-wide AttendancePolicy.officeStartHour /
  // officeEndHour. Lets HR support employees on different schedules
  // (e.g. 9-5 vs the default 10-6) without breaking the org policy.
  // Minute columns are 0..59 and pair with the Hour column to support
  // half-hour shifts like 09:30. Default to 0 so an existing row with
  // shiftStartHour=9 reads back as 09:00 without manual fix-ups.
  shiftStartHour     Int?
  shiftStartMinute   Int?                    @default(0)
  shiftEndHour       Int?
  shiftEndMinute     Int?                    @default(0)
  // Per-employee daily hours override. NULL falls back to the org-wide
  // AttendancePolicy.requiredDailyHours. Lets HR keep some employees on
  // 7-hour days (e.g. interns) without changing the org default.
  requiredDailyHours Decimal?                @db.Decimal(4, 2)
  terminatedAt       DateTime?               @db.Date
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  documents          EmployeeDocument[]
  promotions         PromotionHistory[]
  salaryStructure    SalaryStructure?
  paySlips           PaySlip[]
  hrNotes            HrNote[]
  statusEvents       EmploymentStatusEvent[]
  ledgerEntries      FounderLedgerEntry[]
  equityGrants       EquityGrant[]
}

model EmployeeDocument {
  id         String          @id @default(cuid())
  employeeId String
  employee   EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  title      String
  fileUrl    String
  createdAt  DateTime        @default(now())
}

model PromotionHistory {
  id            String          @id @default(cuid())
  employeeId    String
  employee      EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  previousTitle String
  newTitle      String
  effectiveDate DateTime        @db.Date
  notes         String?
  createdAt     DateTime        @default(now())
}

model Expense {
  id             String         @id @default(cuid())
  title          String
  category       String
  amount         Decimal        @db.Decimal(12, 2)
  spentAt        DateTime       @db.Date
  notes          String?
  approvalStatus ApprovalStatus @default(PENDING_APPROVAL)
  approvedById   String?
  createdById    String
  createdBy      User           @relation("ExpenseCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  transaction    Transaction?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Revenue {
  id          String       @id @default(cuid())
  title       String
  source      String
  amount      Decimal      @db.Decimal(12, 2)
  receivedAt  DateTime     @db.Date
  notes       String?
  createdById String
  createdBy   User         @relation("RevenueCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  transaction Transaction?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Transaction {
  id          String          @id @default(cuid())
  type        TransactionType
  amount      Decimal         @db.Decimal(12, 2)
  reference   String?
  expenseId   String?         @unique
  revenueId   String?         @unique
  expense     Expense?        @relation(fields: [expenseId], references: [id], onDelete: SetNull)
  revenue     Revenue?        @relation(fields: [revenueId], references: [id], onDelete: SetNull)
  createdById String
  createdBy   User            @relation("TransactionCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime        @default(now())
}

model Invoice {
  id              String                   @id @default(cuid())
  invoiceNumber   String                   @unique
  clientId        String
  projectId       String?
  amount          Decimal                  @db.Decimal(12, 2)
  tax             Decimal                  @default(0) @db.Decimal(12, 2)
  total           Decimal                  @db.Decimal(12, 2)
  // Optional advance amount due now (e.g. 50% upfront)
  advanceAmount   Decimal?                 @db.Decimal(12, 2)
  discountAmount  Decimal                  @default(0) @db.Decimal(12, 2)
  status          InvoiceStatus            @default(DRAFT)
  dueDate         DateTime                 @db.Date
  paidAt          DateTime?
  notes           String?
  /**
   * Single-line italic note rendered between the totals card and the bulleted NOTES (e.g. "*Physical shooting not included…").
   */
  leadNote        String?
  /**
   * Client-supplied PO / reference number. Printed near the invoice number as "Ref: …".
   */
  referenceNumber String?
  createdById     String
  client          Client                   @relation(fields: [clientId], references: [id], onDelete: Restrict)
  project         Project?                 @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdBy       User                     @relation("InvoiceCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  items           InvoiceItem[]
  creditNotes     CreditNote[]
  allocations     PaymentAllocation[]
  milestone       ProjectPaymentMilestone? @relation("MilestoneInvoice")
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  @@index([clientId])
  @@index([projectId])
  @@index([status])
  @@index([dueDate])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  itemId      String?
  item        Item?    @relation(fields: [itemId], references: [id], onDelete: SetNull)
  description String
  /**
   * Free-text duration shown in the PROJECT DURATION column on printed invoices (e.g. "2-3 days").
   */
  duration    String?
  quantity    Decimal  @db.Decimal(10, 2)
  price       Decimal  @db.Decimal(12, 2)
  taxRateId   String?
  taxRate     TaxRate? @relation(fields: [taxRateId], references: [id], onDelete: SetNull)
  taxAmount   Decimal  @default(0) @db.Decimal(12, 2)
  total       Decimal  @db.Decimal(12, 2)
  sortOrder   Int      @default(0)
}

model Proposal {
  id                   String                @id @default(cuid())
  clientId             String
  projectId            String?
  projectName          String
  // The headline executive-summary blurb at the top of the proposal.
  description          String
  // Optional client-context paragraph that explains why this engagement is needed.
  projectUnderstanding String?
  timeline             String
  pricing              String
  // Free-form text for the "Investment & Payment Terms" block (e.g. "50% advance · 30% mid · 20% on launch")
  paymentTermsText     String?
  // Validity — proposal expires after this date
  validUntil           DateTime?             @db.Date
  status               ProposalStatus        @default(DRAFT)
  createdById          String
  client               Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project              Project?              @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdBy            User                  @relation(fields: [createdById], references: [id], onDelete: Restrict)
  blocks               ProposalBlock[]
  deliverables         ProposalDeliverable[]
  acceptance           ProposalAcceptance?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
}

model ProposalBlock {
  id            String   @id @default(cuid())
  proposalId    String
  proposal      Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  heading       String
  content       String
  // Optional duration (used by the timeline Gantt visualization)
  durationWeeks Int?
  sortOrder     Int      @default(0)
}

enum DeliverableKind {
  INCLUDED // What the client receives
  EXCLUDED // Out-of-scope / not included
}

model ProposalDeliverable {
  id          String          @id @default(cuid())
  proposalId  String
  proposal    Proposal        @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  kind        DeliverableKind
  title       String
  description String?
  // Optional per-feature price — drives the Pricing Breakdown page
  amount      Decimal?        @db.Decimal(12, 2)
  sortOrder   Int             @default(0)
  createdAt   DateTime        @default(now())

  @@index([proposalId])
}

model ResourceAllocation {
  id             String    @id @default(cuid())
  userId         String
  projectId      String
  allocatedHours Decimal   @db.Decimal(8, 2)
  roleLabel      String
  startDate      DateTime  @db.Date
  endDate        DateTime? @db.Date
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([userId, projectId, startDate])
}

model Document {
  id            String             @id @default(cuid())
  fileUrl       String
  fileName      String
  storageDriver DocumentStorage    @default(LOCAL)
  entityType    DocumentEntityType
  projectId     String?
  clientId      String?
  uploadedById  String
  version       Int                @default(1)
  mimeType      String?
  sizeInBytes   Int?
  project       Project?           @relation(fields: [projectId], references: [id], onDelete: SetNull)
  client        Client?            @relation(fields: [clientId], references: [id], onDelete: SetNull)
  uploadedBy    User               @relation(fields: [uploadedById], references: [id], onDelete: Restrict)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model Notification {
  id        String              @id @default(cuid())
  userId    String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType    @default(GENERIC)
  title     String
  body      String?
  channel   NotificationChannel @default(IN_APP)
  status    NotificationStatus  @default(UNREAD)
  actionUrl String?
  link      String?
  taskId    String?
  projectId String?
  readAt    DateTime?
  createdAt DateTime            @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

/// Org-wide master switches for each notification event. One row per
/// eventKey (a free-form string constant defined in
/// notification-preferences.constants.ts — kept off the Prisma enum so
/// adding new events is a code-only change, not a DB migration). Each
/// row carries two flags: whether email and/or in-app delivery is
/// enabled for that event. Auth-critical sends (password reset, email
/// verify) bypass this gate by design and are not represented here.
model NotificationPreference {
  id           String   @id @default(cuid())
  eventKey     String   @unique
  emailEnabled Boolean  @default(true)
  inAppEnabled Boolean  @default(true)
  updatedAt    DateTime @updatedAt
}

model ReportExport {
  id          String   @id @default(cuid())
  name        String
  type        String
  format      String
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id], onDelete: Restrict)
  fileUrl     String?
  createdAt   DateTime @default(now())
}

// ── Activity/Audit Logs ──

enum ActivityAction {
  CREATED
  UPDATED
  DELETED
  ASSIGNED
  STATUS_CHANGED
  COMMENTED
  APPROVED
  REJECTED
  UPLOADED
  SENT
  LOGGED_IN
}

model ActivityLog {
  id         String         @id @default(cuid())
  userId     String
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  action     ActivityAction
  entityType String
  entityId   String?
  entityName String?
  details    String?
  createdAt  DateTime       @default(now())

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
}

// ── Lead Pipeline (CRM) ──

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  NEGOTIATION
  WON
  LOST
}

model Lead {
