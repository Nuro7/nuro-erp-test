  companyName    String
  contactName    String
  email          String
  phone          String?
  source         String?
  status         LeadStatus @default(NEW)
  estimatedValue Decimal?   @db.Decimal(12, 2)
  notes          String?
  assignedToId   String?
  assignedTo     User?      @relation("LeadAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  convertedToId  String?    @unique
  convertedTo    Client?    @relation("LeadConversion", fields: [convertedToId], references: [id], onDelete: SetNull)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  deal           Deal?      @relation("LeadToDeal")
  activities     Activity[]
}

// ── Holiday Calendar ──

model Holiday {
  id          String   @id @default(cuid())
  name        String
  date        DateTime @db.Date
  type        String   @default("PUBLIC")
  description String?
  createdAt   DateTime @default(now())

  @@unique([date, name])
}

// ── Knowledge Base ──

model KnowledgeArticle {
  id        String   @id @default(cuid())
  title     String
  content   String
  category  String
  authorId  String
  author    User     @relation("ArticleAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Expense Approval ──

enum ApprovalStatus {
  PENDING_APPROVAL
  APPROVED_FINAL
  REJECTED_FINAL
}

// ── Goals / OKRs / KPIs ──

enum GoalStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum GoalType {
  GOAL
  OKR
  KPI
}

model Goal {
  id           String     @id @default(cuid())
  title        String
  description  String?
  type         GoalType   @default(GOAL)
  targetValue  Decimal?   @db.Decimal(12, 2)
  currentValue Decimal?   @db.Decimal(12, 2)
  unit         String?
  status       GoalStatus @default(NOT_STARTED)
  startDate    DateTime?  @db.Date
  dueDate      DateTime?  @db.Date
  assigneeId   String
  assignee     User       @relation("GoalAssignee", fields: [assigneeId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

// ── Vendor Management ──

model Vendor {
  id                String             @id @default(cuid())
  companyName       String
  contactName       String?
  email             String?
  phone             String?
  address           String?
  category          String?
  notes             String?
  status            String             @default("ACTIVE")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  bills             Bill[]
  payments          Payment[]
  projectExpenses   ProjectExpense[]
  recurringExpenses RecurringExpense[]
}

enum ProjectExpenseCategory {
  SUBSCRIPTION
  RENT
  UTILITY
  TRAVEL
  SOFTWARE
  EQUIPMENT
  HOSTING
  MARKETING
  CONTRACTOR
  OTHER
}

model ProjectExpense {
  id               String                 @id @default(cuid())
  projectId        String
  project          Project                @relation("ProjectExpenses", fields: [projectId], references: [id], onDelete: Cascade)
  category         ProjectExpenseCategory @default(OTHER)
  description      String
  amount           Decimal                @db.Decimal(12, 2)
  incurredAt       DateTime
  recurring        Boolean                @default(false)
  recurrenceMonths Int?
  notes            String?
  vendorId         String?
  vendor           Vendor?                @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  createdById      String?
  createdBy        User?                  @relation("ProjectExpensesCreated", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@index([projectId, incurredAt])
  @@index([category])
}

// ── Calendar / Meetings / Appointments ──

enum EventType {
  MEETING
  APPOINTMENT
  REMINDER
  EVENT
}

model CalendarEvent {
  id          String    @id @default(cuid())
  title       String
  description String?
  type        EventType @default(EVENT)
  startTime   DateTime
  endTime     DateTime?
  allDay      Boolean   @default(false)
  location    String?
  organizerId String
  organizer   User      @relation("EventOrganizer", fields: [organizerId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ── Employee Onboarding ──

model OnboardingChecklist {
  id          String           @id @default(cuid())
  title       String
  description String?
  items       OnboardingItem[]
  createdAt   DateTime         @default(now())
}

model OnboardingItem {
  id          String              @id @default(cuid())
  checklistId String
  checklist   OnboardingChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  title       String
  completed   Boolean             @default(false)
  assigneeId  String?
  sortOrder   Int                 @default(0)
  createdAt   DateTime            @default(now())
}

// ── Communication History ──

model Communication {
  id          String   @id @default(cuid())
  clientId    String?
  leadId      String?
  type        String
  subject     String
  content     String?
  direction   String   @default("OUTBOUND")
  createdById String
  createdBy   User     @relation("CommunicationCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime @default(now())
}

// ── Office Location / Geo-fencing ──

model OfficeSettings {
  id                 String   @id @default(cuid())
  name               String   @default("Main Office")
  latitude           Float
  longitude          Float
  radiusMeters       Int      @default(100)
  geofenceEnabled    Boolean  @default(false)
  // Comma-separated list of trusted office IPs / CIDR blocks. When a
  // clock-in comes from one of these, the API accepts it even if the
  // device couldn't share GPS — laptops on the office WiFi count as
  // "at the office" the same way a phone with a valid GPS lock does.
  // Examples: "203.0.113.42, 198.51.100.0/24, 2001:db8::/32".
  allowedIpAddresses String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// ── Email Templates ──

model EmailTemplate {
  id          String   @id @default(cuid())
  name        String
  subject     String
  body        String
  category    String   @default("GENERAL")
  createdById String
  createdBy   User     @relation("TemplateCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ══════════════════════════════════════════════════════════════════
// CRM EXPANSION — Contacts, Deals, Activities (Zoho CRM parity)
// ══════════════════════════════════════════════════════════════════

model Contact {
  id         String     @id @default(cuid())
  clientId   String
  client     Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  firstName  String
  lastName   String
  email      String?
  phone      String?
  mobile     String?
  title      String?
  department String?
  isPrimary  Boolean    @default(false)
  notes      String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  deals      Deal[]
  activities Activity[]

  @@index([clientId])
}

enum DealStage {
  PROSPECTING
  QUALIFICATION
  PROPOSAL
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

model Deal {
  id                String     @id @default(cuid())
  name              String
  clientId          String
  client            Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  contactId         String?
  contact           Contact?   @relation(fields: [contactId], references: [id], onDelete: SetNull)
  leadId            String?    @unique
  lead              Lead?      @relation("LeadToDeal", fields: [leadId], references: [id], onDelete: SetNull)
  stage             DealStage  @default(PROSPECTING)
  amount            Decimal    @db.Decimal(14, 2)
  probability       Int        @default(50)
  expectedCloseDate DateTime?  @db.Date
  actualCloseDate   DateTime?  @db.Date
  ownerId           String
  owner             User       @relation("DealOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  description       String?
  lostReason        String?
  source            String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  activities        Activity[]

  @@index([stage])
  @@index([ownerId])
  @@index([clientId])
}

enum ActivityType {
  CALL
  EMAIL
  MEETING
  NOTE
  TASK
}

model Activity {
  id           String       @id @default(cuid())
  type         ActivityType
  subject      String
  description  String?
  dueDate      DateTime?
  completedAt  DateTime?
  leadId       String?
  lead         Lead?        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  dealId       String?
  deal         Deal?        @relation(fields: [dealId], references: [id], onDelete: Cascade)
  clientId     String?
  client       Client?      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  contactId    String?
  contact      Contact?     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  createdById  String
  createdBy    User         @relation("ActivityCreator", fields: [createdById], references: [id], onDelete: Restrict)
  assignedToId String?
  assignedTo   User?        @relation("ActivityAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([leadId])
  @@index([dealId])
  @@index([clientId])
}

// ══════════════════════════════════════════════════════════════════
// ACCOUNTING — Chart of Accounts, Items, Tax, Org Settings
// ══════════════════════════════════════════════════════════════════

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}

enum AccountSubType {
  CASH
  BANK
  ACCOUNTS_RECEIVABLE
  CURRENT_ASSET
  FIXED_ASSET
  OTHER_ASSET
  ACCOUNTS_PAYABLE
  CURRENT_LIABILITY
  LONG_TERM_LIABILITY
  OWNER_EQUITY
  RETAINED_EARNINGS
  OPERATING_REVENUE
  OTHER_INCOME
  COST_OF_GOODS_SOLD
  OPERATING_EXPENSE
  PAYROLL_EXPENSE
  OTHER_EXPENSE
  TAX_PAYABLE
}

model ChartAccount {
  id               String            @id @default(cuid())
  code             String            @unique
  name             String
  type             AccountType
  subType          AccountSubType
  parentId         String?
  parent           ChartAccount?     @relation("AccountTree", fields: [parentId], references: [id], onDelete: SetNull)
