  invoiceItems          InvoiceItem[]
  estimateItems         EstimateItem[]
  billItems             BillItem[]
  creditNoteItems       CreditNoteItem[]
  recurringInvoiceItems RecurringInvoiceItem[]
}

enum ItemType {
  GOODS
  SERVICE
}

model Item {
  id                    String                 @id @default(cuid())
